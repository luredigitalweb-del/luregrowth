# Copie este arquivo para .env.mcp.local e preencha os valores reais.
# Estas variaveis sao consumidas pelo .mcp.json deste projeto.
# IMPORTANTE: o Claude Code le do ambiente do shell que o lanca.
# No Windows (PowerShell), antes de abrir o Claude Code rode:
#   Get-Content .env.mcp.local | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process') } }
# No bash/git-bash:
#   set -a; source .env.mcp.local; set +a

# Supabase: gere em https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# GitHub: gere em https://github.com/settings/tokens (escopo: repo, read:org)
GITHUB_TOKEN=

# Sentry: gere em https://sentry.io/settings/account/api/auth-tokens/
# Escopos: project:read, event:read, org:read
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=auto-lure
